{
  "gateway": {
    "mode": "gateway",
    "bind": "127.0.0.1",
    "port": 18789,
    "http": {
      "endpoints": [
        "local"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "optional",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": []
    }
  },
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "thinkingDefault": "medium",
      "model": {
        "primary": "openai/gpt-5.2",
        "fallbacks": [
          "anthropic-api/claude-sonnet-4-6"
        ]
      },
      "memorySearch": {
        "enabled": true,
        "provider": "local",
        "fallback": "none"
      },
      "maxConcurrent": 1
    },
    "list": [
      {
        "id": "main",
        "workspace": "./workspace",
        "botName": "DOC"
      },
      {
        "id": "codex",
        "workspace": "./workspace-codex",
        "botName": "CODEX"
      },
      {
        "id": "pa",
        "workspace": "./workspace-pa",
        "botName": "PA"
      },
      {
        "id": "hk",
        "workspace": "./workspace-hk",
        "botName": "HK"
      }
    ]
  },
  "bindings": [],
  "models": {
    "providers": {
      "openai": {
        "apiKey": "${OPENAI_API_KEY}"
      },
      "anthropic-api": {
        "apiKey": "${ANTHROPIC_API_KEY}"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "accounts": {
        "main": {
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "allowFrom": [
            "${TELEGRAM_OWNER_CHAT_ID}"
          ],
          "sessionKey": "agent:pa:intake"
        }
      },
      "heartbeat": {
        "enabled": true
      }
    },
    "whatsapp": {
      "enabled": false,
      "allowFrom": [
        "${WHATSAPP_OWNER_ID}"
      ],
      "dmPolicy": "allow",
      "groupPolicy": "manual",
      "heartbeat": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "enabled": false,
    "path": "/hooks",
    "token": "${OPENCLAW_HOOKS_TOKEN}",
    "defaultSessionKey": "agent:main:main",
    "allowRequestSessionKey": false,
    "allowedSessionKeyPrefixes": [
      "agent:"
    ],
    "transformsDir": "./hooks/transforms",
    "presets": [],
    "mappings": [],
    "gmail": {
      "enabled": false,
      "account": "primary",
      "watchTopic": "${GMAIL_WATCH_TOPIC}"
    }
  },
  "messages": {
    "ackReactionScope": "owner"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": false,
    "ownerDisplay": "raw"
  },
  "tools": {
    "profile": "public-core",
    "web": {
      "search": true,
      "fetch": true
    },
    "media": {
      "concurrency": 2
    },
    "sessions": {
      "visibility": "owner"
    },
    "message": {
      "allowCrossContextSend": false
    },
    "agentToAgent": {
      "enabled": true
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "./skills"
      ]
    },
    "install": {
      "nodeManager": "manual"
    },
    "entries": {}
  },
  "wizard": {
    "lastRunAt": null,
    "lastRunVersion": null,
    "lastRunCommand": null,
    "lastRunMode": "manual"
  },
  "plugins": {
    "entries": {}
  },
  "auth": {
    "profiles": {}
  }
}
